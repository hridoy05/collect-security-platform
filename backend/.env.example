PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://connect_admin:connect_secret_2024@localhost:5432/connect_security

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT — use RS256 in production with proper key pair
JWT_SECRET=connect_jwt_secret_super_secure_change_in_production_min_32_chars

# AES-256 encryption key — exactly 64 hex chars = 32 bytes
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
